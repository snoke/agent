# n8n (passed into the container via docker-compose `env_file: .env`)
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/
# Optional alias (older docs / compatibility)
N8N_WEBHOOK_URL=http://localhost:5678/
TZ=Europe/Berlin
GENERIC_TIMEZONE=Europe/Berlin
N8N_DIAGNOSTICS_ENABLED=false
N8N_PERSONALIZATION_ENABLED=false
N8N_CORS_ENABLED=true
N8N_CORS_ALLOW_ORIGIN=http://localhost:8080
# Allow workflows to read $env.* (needed for policy via .env)
N8N_BLOCK_ENV_ACCESS_IN_NODE=false

# Booking policy (used by the n8n workflow)
# Timezone for parsing/booking (should match TZ for best results)
AGENT_TZ=Europe/Berlin
# Allowed weekdays (1=Mon ... 5=Fri)
AGENT_WORKDAYS=1,2,3,4,5
# Allowed hours (24h, inclusive start, exclusive end)
AGENT_WORK_START=09:00
AGENT_WORK_END=17:00
# How far ahead bookings are allowed
AGENT_HORIZON_DAYS=30
# Minimum lead time (hours) from now for bookings
AGENT_MIN_LEAD_HOURS=24

# Require additional fields before booking (comma-separated; any order)
# Options: email,name,phone,note
# Examples:
# REQUIRE_INPUT=email
# REQUIRE_INPUT=email,name
# REQUIRE_INPUT=email,name,phone
REQUIRE_INPUT=email

# Ask for optional fields before booking (comma-separated; any order)
# Options: email,name,phone,note
# Examples:
# OPTIONAL_INPUT=note
# OPTIONAL_INPUT=name,note
# OPTIONAL_INPUT=email,phone,note
OPTIONAL_INPUT=note

# Attach a Google Meet link to newly created calendar events
# (Default: true)
CREATE_GOOGLE_MEET=true

# Speech-to-text model for the voice webhook (OpenAI)
AGENT_STT_MODEL=gpt-4o-mini-transcribe

# OpenAI API credentials are configured inside n8n (Credentials -> OpenAI).
# No OPENAI_API_KEY env var is required.

# Recommended (set a long random secret):
# N8N_ENCRYPTION_KEY=
